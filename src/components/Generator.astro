---
// src/components/Generator.astro
---
<div class="w-full max-w-4xl mx-auto mt-20 relative z-10 px-4">
  <div class="glass rounded-3xl p-8 md:p-12 border border-purple-500/30">
    <h2 class="text-3xl font-bold text-center mb-8 bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
      Generador de Keys
    </h2>
    
    <div class="flex flex-col items-center gap-6">
      <button 
        id="generateBtn"
        class="px-10 py-4 bg-gradient-to-r from-purple-600 to-pink-600 rounded-xl text-white font-bold text-lg hover:scale-105 transition-transform disabled:opacity-50">
        ✨ Generar Key
      </button>
      
      <div id="keyResult" class="hidden w-full max-w-2xl mt-4 p-6 rounded-xl bg-black/30 border border-purple-500/30">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <code id="keyCode" class="text-xl md:text-2xl font-mono text-green-400 break-all"></code>
          <button id="copyBtn" class="px-4 py-2 bg-purple-600/50 rounded-lg hover:bg-purple-600 transition-all text-white whitespace-nowrap">
            📋 Copiar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Cargar Supabase desde CDN
  const script = document.createElement('script');
  script.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2';
  script.onload = function() {
    // Configuración
    const SUPABASE_URL = 'https://mtpboiuvqfunbdcdsaug.supabase.co';  // ⚠️ CAMBIAR
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10cGJvaXV2cWZ1bmJkY2RzYXVnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA0MzU2NDEsImV4cCI6MjA5NjAxMTY0MX0.4FP6ZQpiZSBx1XtXpl1D40TSkWujsbjDvEeBQj3hROE';                 // ⚠️ CAMBIAR
    
    const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // Elementos
    const generateBtn = document.getElementById('generateBtn');
    const keyResult = document.getElementById('keyResult');
    const keyCode = document.getElementById('keyCode');
    const copyBtn = document.getElementById('copyBtn');

    // Generar key
    generateBtn.addEventListener('click', async () => {
      // Key aleatoria
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      const segments = [];
      for (let i = 0; i < 4; i++) {
        let segment = '';
        for (let j = 0; j < 4; j++) {
          segment += chars[Math.floor(Math.random() * chars.length)];
        }
        segments.push(segment);
      }
      const key = 'AST-' + segments.join('-');

      // Loading
      generateBtn.disabled = true;
      generateBtn.textContent = '⏳ Generando...';

      // Guardar
      const { error } = await supabase
        .from('keys')
        .insert([{ key, is_active: true }]);

      if (error) {
        alert('Error: ' + error.message);
        generateBtn.disabled = false;
        generateBtn.textContent = '✨ Generar Key';
        return;
      }

      // Mostrar
      keyCode.textContent = key;
      keyResult.classList.remove('hidden');
      generateBtn.disabled = false;
      generateBtn.textContent = '✨ Generar Key';
    });

    // Copiar
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(keyCode.textContent);
      copyBtn.textContent = '✅ Copiado!';
      setTimeout(() => { copyBtn.textContent = '📋 Copiar'; }, 2000);
    });
  };
  document.head.appendChild(script);
</script>
