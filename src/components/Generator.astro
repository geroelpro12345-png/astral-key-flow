---
// src/components/Generator.astro
---
<div class="w-full max-w-4xl mx-auto mt-20 px-4">
  <div class="glass rounded-3xl p-8 md:p-12 border border-purple-500/30">
    <h2 class="text-3xl font-bold text-center mb-8 bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
      Generador de Keys
    </h2>
    
    <div class="flex flex-col items-center gap-6">
      <button id="generateBtn" class="px-10 py-4 bg-gradient-to-r from-purple-600 to-pink-600 rounded-xl text-white font-bold text-lg hover:scale-105 transition-transform">
        ✨ Generar Key
      </button>
      
      <div id="keyResult" class="hidden w-full max-w-2xl mt-4 p-6 rounded-xl bg-black/30 border border-purple-500/30">
        <div class="flex items-center justify-between gap-4">
          <code id="keyCode" class="text-2xl font-mono text-green-400"></code>
          <button id="copyBtn" class="px-4 py-2 bg-purple-600/50 rounded-lg hover:bg-purple-600 transition-all text-white">
            📋 Copiar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { createClient } from '@supabase/supabase-js'

  const supabase = createClient('TU_URL', 'TU_ANON_KEY')

  document.getElementById('generateBtn').addEventListener('click', async () => {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'
    const segments = []
    for (let i = 0; i < 4; i++) {
      let segment = ''
      for (let j = 0; j < 4; j++) {
        segment += chars[Math.floor(Math.random() * chars.length)]
      }
      segments.push(segment)
    }
    const key = 'AST-' + segments.join('-')
    
    const btn = document.getElementById('generateBtn')
    btn.disabled = true
    btn.textContent = '⏳ Generando...'
    
    const { error } = await supabase.from('keys').insert([{ key, is_active: true }])
    
    if (error) { alert('Error'); btn.disabled = false; return }
    
    document.getElementById('keyCode').textContent = key
    document.getElementById('keyResult').classList.remove('hidden')
    btn.disabled = false
    btn.textContent = '✨ Generar Key'
  })

  document.getElementById('copyBtn').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('keyCode').textContent)
  })
</script>
