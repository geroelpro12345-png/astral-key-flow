---
// src/components/Generator.astro
---
<div class="w-full max-w-4xl mx-auto mt-20 relative z-10 px-4">
  <div class="glass rounded-3xl p-8 md:p-12 border border-purple-500/30">
    <h2 class="text-3xl font-bold text-center mb-8 bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
      Generador de Keys
    </h2>
    
    <div class="flex flex-col items-center gap-6">
      <button 
        id="generateBtn"
        class="px-10 py-4 bg-gradient-to-r from-purple-600 to-pink-600 rounded-xl text-white font-bold text-lg hover:scale-105 transition-transform disabled:opacity-50">
        ✨ Generar Key
      </button>
      
      <div id="keyResult" class="hidden w-full max-w-2xl mt-4 p-6 rounded-xl bg-black/30 border border-purple-500/30">
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <code id="keyCode" class="text-xl md:text-2xl font-mono text-green-400 break-all"></code>
          <button id="copyBtn" class="px-4 py-2 bg-purple-600/50 rounded-lg hover:bg-purple-600 transition-all text-white whitespace-nowrap">
            📋 Copiar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Tu configuración de Supabase
  const SUPABASE_URL = 'https://mtpboiuvqfunbdcdsaug.supabase.co'
  const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im10cGJvaXV2cWZ1bmJkY2RzYXVnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA0MzU2NDEsImV4cCI6MjA5NjAxMTY0MX0.4FP6ZQpiZSBx1XtXpl1D40TSkWujsbjDvEeBQj3hROE'
  
  function generateKey() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'
    const segments = []
    for (let i = 0; i < 4; i++) {
      let segment = ''
      for (let j = 0; j < 4; j++) {
        segment += chars[Math.floor(Math.random() * chars.length)]
      }
      segments.push(segment)
    }
    return 'AST-' + segments.join('-')
  }

  document.addEventListener('DOMContentLoaded', () => {
    const generateBtn = document.getElementById('generateBtn')
    const keyResult = document.getElementById('keyResult')
    const keyCode = document.getElementById('keyCode')
    const copyBtn = document.getElementById('copyBtn')

    generateBtn.addEventListener('click', async () => {
      const key = generateKey()
      
      generateBtn.disabled = true
      generateBtn.textContent = '⏳ Generando...'
      
      try {
        const response = await fetch(`${SUPABASE_URL}/rest/v1/keys`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({ 
            key: key, 
            is_active: true,
            created_at: new Date().toISOString()
          })
        })

        if (!response.ok) {
          const error = await response.json()
          throw new Error(error.message || 'Error al crear key')
        }

        keyCode.textContent = key
        keyResult.classList.remove('hidden')
        keyResult.style.transform = 'scale(1.05)'
        setTimeout(() => {
          keyResult.style.transform = 'scale(1)'
        }, 200)
        
      } catch (error) {
        console.error('Error:', error)
        alert('Error al generar key: ' + error.message)
      } finally {
        generateBtn.disabled = false
        generateBtn.textContent = '✨ Generar Key'
      }
    })

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(keyCode.textContent)
        copyBtn.textContent = '✅ Copiado!'
        copyBtn.style.backgroundColor = '#10B981'
        setTimeout(() => {
          copyBtn.textContent = '📋 Copiar'
          copyBtn.style.backgroundColor = ''
        }, 2000)
      } catch (err) {
        alert('Error al copiar al portapapeles')
      }
    })
  })
</script>
